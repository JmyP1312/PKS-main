@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Товары</PageTitle>

<section class="toolbar">
    <div>
        <h1>Товары</h1>
        <p class="muted">Каталог интернет-магазина с хранением данных в SQLite через ASP.NET Core API.</p>
    </div>

    <label class="theme-switch">
        <input type="checkbox" checked="@isDarkTheme" @onchange="ToggleTheme" />
        <span>Темная тема</span>
    </label>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<section class="product-workspace">
    <div class="product-list">
        <div class="list-header">
            <div>
                <h2>Список товаров</h2>
                <span class="muted">@FilteredProducts.Count() из @products.Count</span>
            </div>
            <input class="form-control search-input"
                   placeholder="Поиск по названию или категории"
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>

        @if (isLoading)
        {
            <div class="empty-state">Загрузка товаров...</div>
        }
        else if (!FilteredProducts.Any())
        {
            <div class="empty-state">Товары не найдены.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle product-table">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Категория</th>
                            <th>Цена</th>
                            <th>Остаток</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in FilteredProducts)
                        {
                            <tr>
                                <td>
                                    <strong>@product.Name</strong>
                                    @if (!string.IsNullOrWhiteSpace(product.Description))
                                    {
                                        <span class="description">@product.Description</span>
                                    }
                                </td>
                                <td><span class="category">@product.Category</span></td>
                                <td>@product.Price.ToString("C0", culture)</td>
                                <td>@product.Stock шт.</td>
                                <td class="text-end actions">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(product)">Изменить</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(product)">Удалить</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="product-form-panel">
        <h2>@(isEditing ? "Изменение товара" : "Добавление товара")</h2>

        <EditForm Model="formProduct" OnValidSubmit="SaveProduct">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label" for="name">Название</label>
                <InputText id="name" class="form-control" @bind-Value="formProduct.Name" />
                <ValidationMessage For="@(() => formProduct.Name)" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="category">Категория</label>
                <InputText id="category" class="form-control" @bind-Value="formProduct.Category" />
                <ValidationMessage For="@(() => formProduct.Category)" />
            </div>

            <div class="form-grid">
                <div class="mb-3">
                    <label class="form-label" for="price">Цена</label>
                    <InputNumber id="price" class="form-control" @bind-Value="formProduct.Price" />
                    <ValidationMessage For="@(() => formProduct.Price)" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="stock">Остаток</label>
                    <InputNumber id="stock" class="form-control" @bind-Value="formProduct.Stock" />
                    <ValidationMessage For="@(() => formProduct.Stock)" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="description">Описание</label>
                <InputTextArea id="description" class="form-control" rows="3" @bind-Value="formProduct.Description" />
                <ValidationMessage For="@(() => formProduct.Description)" />
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">@(isEditing ? "Сохранить" : "Добавить")</button>
                @if (isEditing)
                {
                    <button class="btn btn-outline-secondary" type="button" @onclick="ResetForm">Отмена</button>
                }
            </div>
        </EditForm>
    </div>
</section>

@code {
    private readonly System.Globalization.CultureInfo culture = new("ru-RU");
    private List<Product> products = [];
    private Product formProduct = new();
    private bool isLoading = true;
    private bool isEditing;
    private bool isDarkTheme;
    private string searchText = string.Empty;
    private string? errorMessage;

    private IEnumerable<Product> FilteredProducts => string.IsNullOrWhiteSpace(searchText)
        ? products
        : products.Where(product =>
            product.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || product.Category.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var theme = await JS.InvokeAsync<string>("storeTheme.get");
        isDarkTheme = theme == "dark";
        StateHasChanged();
    }

    private async Task LoadProducts()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            products = await Http.GetFromJsonAsync<List<Product>>("api/products") ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Не удалось загрузить товары: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProduct()
    {
        try
        {
            errorMessage = null;

            if (isEditing)
            {
                var response = await Http.PutAsJsonAsync($"api/products/{formProduct.Id}", formProduct);
                response.EnsureSuccessStatusCode();
            }
            else
            {
                var response = await Http.PostAsJsonAsync("api/products", formProduct);
                response.EnsureSuccessStatusCode();
            }

            ResetForm();
            await LoadProducts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Не удалось сохранить товар: {ex.Message}";
        }
    }

    private void StartEdit(Product product)
    {
        isEditing = true;
        formProduct = new Product
        {
            Id = product.Id,
            Name = product.Name,
            Category = product.Category,
            Price = product.Price,
            Stock = product.Stock,
            Description = product.Description
        };
    }

    private async Task DeleteProduct(Product product)
    {
        var confirmed = await JS.InvokeAsync<bool>("storeTheme.confirmDelete", product.Name);
        if (!confirmed)
        {
            return;
        }

        try
        {
            errorMessage = null;
            var response = await Http.DeleteAsync($"api/products/{product.Id}");
            response.EnsureSuccessStatusCode();

            if (isEditing && formProduct.Id == product.Id)
            {
                ResetForm();
            }

            await LoadProducts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Не удалось удалить товар: {ex.Message}";
        }
    }

    private async Task ToggleTheme(ChangeEventArgs args)
    {
        isDarkTheme = args.Value is true || string.Equals(args.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        await JS.InvokeVoidAsync("storeTheme.set", isDarkTheme ? "dark" : "light");
    }

    private void ResetForm()
    {
        isEditing = false;
        formProduct = new Product();
    }
}
